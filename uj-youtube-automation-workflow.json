    {
      "id": "a1b2c3d4-0002",
      "name": "Telegram — Receive Topic",
      "type": "n8n-nodes-base.telegramTrigger",
      "typeVersion": 1.1,
      "position": [-200, 460],
      "parameters": {
        "updates": ["message"],
        "additionalFields": {}
