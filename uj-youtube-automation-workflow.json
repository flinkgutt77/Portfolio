    {
      "id": "a1b2c3d4-0003",
      "name": "Set Topic",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [60, 360],
      "parameters": {
        "jsCode": "const input = $input.first();\n\nlet topic;\nif (input.json.message && input.json.message.text) {\n  const text = input.json.message.text.trim();\n  topic = text.replace(/^\\/create\\s*/i, '').trim();\n  if (!topic) topic = 'South Asian Wedding Photography in Norway';\n} else {\n  topic = 'South Asian Wedding Photography in Norway';\n}\n\nreturn [{ json: { topic, triggered_by: input.json.message ? 'telegram' : 'schedule' } }];"
      }
    },
    {
      "id": "a1b2c3d4-0004",
      "name": "Claude — Generate Content",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [300, 360],
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "authentication": "none",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "x-api-key", "value": "={{ $env.ANTHROPIC_API_KEY }}" },
            { "name": "anthropic-version", "value": "2023-06-01" },
            { "name": "content-type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-sonnet-4-20250514\",\n  \"max_tokens\": 2048,\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"You are a content strategist for UJ Studio Norge — South Asian wedding photography and filmmaking studio in Norway run by Umar Javed. Create YouTube content for this topic: {{ $json.topic }}\\n\\nBrand voice: cinematic, authentic, culturally grounded. Audience: South Asian (Pakistani/Indian) couples in Norway + global wedding filmmakers.\\n\\nReturn ONLY a valid JSON object (no markdown fences, no explanation) with exactly these keys:\\n{\\n  \\\"youtube_title\\\": \\\"compelling SEO title under 70 chars\\\",\\n  \\\"youtube_description\\\": \\\"full YouTube description with hook opening line, 3-4 paragraphs, timestamps placeholder, and 10 relevant hashtags\\\",\\n  \\\"youtube_tags\\\": [\\\"tag1\\\", \\\"tag2\\\", \\\"tag3\\\", \\\"tag4\\\", \\\"tag5\\\", \\\"tag6\\\", \\\"tag7\\\", \\\"tag8\\\"],\\n  \\\"hook_30sec\\\": \\\"spoken 30-second hook script to open the video\\\",\\n  \\\"script_outline\\\": \\\"full video script outline with 5-7 labeled sections\\\",\\n  \\\"pollo_ai_prompt\\\": \\\"cinematic video generation prompt for Kling AI v2.1 — describe visual style, lighting, movement, mood in detail\\\",\\n  \\\"instagram_caption_en\\\": \\\"Instagram caption in English, 150-200 words, emotional, ends with CTA, 10-15 hashtags\\\",\\n  \\\"instagram_caption_no\\\": \\\"same caption in Norwegian with Norwegian hashtags\\\",\\n  \\\"tiktok_caption\\\": \\\"TikTok caption under 150 chars, punchy, 3-5 hashtags\\\",\\n  \\\"thumbnail_concept\\\": \\\"detailed thumbnail design description — layout, text overlay, color, emotion\\\"\\\n}\"\n    }\n  ]\n}"
      }
    },
    {
      "id": "a1b2c3d4-0005",
      "name": "Parse Claude Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [560, 360],
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst rawText = response.content[0].text;\n\nconst cleaned = rawText\n  .replace(/^```json\\s*/i, '')\n  .replace(/^```\\s*/i, '')\n  .replace(/```\\s*$/i, '')\n  .trim();\n\nlet parsed;\ntry {\n  parsed = JSON.parse(cleaned);\n} catch (e) {\n  throw new Error('Claude returned invalid JSON. Raw: ' + rawText.substring(0, 300));\n}\n\nconst contentId = 'YT-' + new Date().toISOString().slice(0, 10).replace(/-/g, '') + '-' + Math.random().toString(36).slice(2, 6).toUpperCase();\nconst today = new Date().toISOString().slice(0, 10);\nconst topic = $('Set Topic').first().json.topic;\n\nreturn [{\n  json: {\n    content_id: contentId,\n    date: today,\n    topic,\n    youtube_title: parsed.youtube_title || '',\n    youtube_description: parsed.youtube_description || '',\n    youtube_tags: Array.isArray(parsed.youtube_tags) ? parsed.youtube_tags.join(', ') : (parsed.youtube_tags || ''),\n    hook_30sec: parsed.hook_30sec || '',\n    script_outline: parsed.script_outline || '',\n    pollo_ai_prompt: parsed.pollo_ai_prompt || '',\n    instagram_caption_en: parsed.instagram_caption_en || '',\n    instagram_caption_no: parsed.instagram_caption_no || '',\n    tiktok_caption: parsed.tiktok_caption || '',\n    thumbnail_concept: parsed.thumbnail_concept || '',\n    status: 'pending_review'\n  }\n}];"
      }
    },
